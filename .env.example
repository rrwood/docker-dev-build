# Example environment file for LiteLLM + Claude Code
# Copy this to .env and fill in your actual API key

# Google AI Studio API Key
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# These are set automatically when using the helper scripts
# but you can also export them manually
ANTHROPIC_BASE_URL=http://localhost:4000
ANTHROPIC_API_KEY=DUMMY_KEY
ANTHROPIC_AUTH_TOKEN=DUMMY_KEY
ANTHROPIC_MODEL=gemini-2.5-flash
