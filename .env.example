# Container Configuration
# USERNAME - The user account created in the container (also used for SSH login)
USERNAME=devuser

# USER_PASSWORD - Initial password (CHANGE THIS AFTER DEPLOYMENT using ~/setup/change-password.sh)
USER_PASSWORD=changeme123

# CONTAINER_NAME - Docker container name (as shown in 'docker ps')
CONTAINER_NAME=docker-dev

# HOSTNAME - Container hostname (shown in shell prompt)
HOSTNAME=docker-dev

# CONTAINER_IP - Static IP address for the container on macvlan network
CONTAINER_IP=192.168.111.15

# Workspace Configuration
WORKSPACE_PATH=./workspace
TIMEZONE=UTC

# Optional: Install ngrok during build (true/false)
INSTALL_NGROK=false
NGROK_AUTH_TOKEN=

# GitHub Repository Configuration (usually don't need to change)
GITHUB_REPO=https://github.com/rrwood/docker-dev-build.git
GITHUB_BRANCH=main
