# Portainer Environment File
# This file is committed to the repository for use with Portainer Git deployments
# Copy this to your own file (like env.yourname.home) and customize

# Container Configuration
USERNAME=devuser
USER_PASSWORD=changeme123
CONTAINER_NAME=docker-dev
CONTAINER_HOSTNAME=docker-dev
CONTAINER_IP=192.168.111.15

# Workspace Configuration
WORKSPACE_PATH=./workspace
TIMEZONE=UTC

# Optional: Install ngrok during build (true/false)
INSTALL_NGROK=false
NGROK_AUTH_TOKEN=

# GitHub Repository Configuration (usually don't need to change)
GITHUB_REPO=https://github.com/rrwood/docker-dev-build.git
GITHUB_BRANCH=main
